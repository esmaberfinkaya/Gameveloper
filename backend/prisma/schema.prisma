generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GAMER
  DEVELOPER
  ADMIN
}

enum PostType {
  QUESTION
  IDEA
  ROADMAP
  PROJECT
}

model User {
  id           Int           @id @default(autoincrement())
  email        String        @unique
  name         String
  password     String
  role         Role          @default(GAMER)
  trustScore   Int           @default(0)
  avatar       String?       @db.Text
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  
  posts        Post[]
  comments     Comment[]
  partnerships Partnership[]
  messages     Message[]

  projects     Project[]
  roadmaps     Roadmap[]
  likes        Like[]

  chatRoomsAsUser1 ChatRoom[] @relation("ChatRoomUser1")
  chatRoomsAsUser2 ChatRoom[] @relation("ChatRoomUser2")
  directMessages   DirectMessage[]
}

model Post {
  id         Int       @id @default(autoincrement())
  title      String
  content    String    @db.Text
  story      String?   @db.Text
  visuals    String?   @db.Text
  gameplay   String?   @db.Text
  category   String
  imageUrl   String?   @db.Text
  postType   PostType
  isResolved Boolean   @default(false)
  userId     Int
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user       User      @relation(fields: [userId], references: [id])
  comments   Comment[]
  likes      Like[]
}

model Comment {
  id         Int      @id @default(autoincrement())
  content    String   @db.Text
  isPrivate  Boolean  @default(false)
  type       String   @default("COMMENT") // "COMMENT" or "SOLUTION"
  isAccepted Boolean  @default(false)
  userId     Int
  postId     Int
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
}

model Partnership {
  id           Int      @id @default(autoincrement())
  title        String
  description  String   @db.Text
  requiredRole String
  isUrgent     Boolean  @default(false)
  userId       Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User     @relation(fields: [userId], references: [id])
  messages     Message[]
}

model Message {
  id            Int         @id @default(autoincrement())
  content       String      @db.Text
  senderId      Int
  partnershipId Int
  createdAt     DateTime    @default(now())

  sender        User        @relation(fields: [senderId], references: [id])
  partnership   Partnership @relation(fields: [partnershipId], references: [id], onDelete: Cascade)
}

model ChatRoom {
  id        String   @id @default(uuid())
  user1Id   Int
  user2Id   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user1     User     @relation("ChatRoomUser1", fields: [user1Id], references: [id])
  user2     User     @relation("ChatRoomUser2", fields: [user2Id], references: [id])
  messages  DirectMessage[]

  @@unique([user1Id, user2Id])
}

model DirectMessage {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  roomId    String
  senderId  Int
  createdAt DateTime @default(now())

  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id])
}

model Project {
  id         Int      @id @default(autoincrement())
  title      String
  summary    String   @db.Text
  youtubeUrl  String?
  videoDesc   String?
  storeUrl    String?
  images      Json?    
  releaseDate String?
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id])
  likes      Like[]
}

model Roadmap {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  steps       Json     
  userId      Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  likes       Like[]
}

model Like {
  id        Int      @id @default(autoincrement())
  userId    Int
  postId    Int?
  projectId Int?
  roadmapId Int?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roadmap   Roadmap? @relation(fields: [roadmapId], references: [id], onDelete: Cascade)
}
